{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    { "path": "/api/cron/harvest-wallets", "schedule": "0 0 * * *" }
  ],
  "redirects": [
    { "source": "/marketing/:path*", "destination": "/", "permanent": false }
  ],
  "rewrites": [
    {
      "source": "/launch",
      "destination": "/marketing/07-website-conversion/landing-pages/coming-soon.html"
    },
    {
      "source": "/waitlist",
      "destination": "/marketing/07-website-conversion/landing-pages/coming-soon.html"
    },
    {
      "source": "/drop",
      "destination": "/marketing/07-website-conversion/landing-pages/coming-soon.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=5, stale-while-revalidate=30" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/og-coming-soon.gif",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=86400, stale-while-revalidate=604800" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
