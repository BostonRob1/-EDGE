{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/launch",
      "destination": "/marketing/07-website-conversion/landing-pages/coming-soon.html"
    },
    {
      "source": "/waitlist",
      "destination": "/marketing/07-website-conversion/landing-pages/coming-soon.html"
    },
    {
      "source": "/drop",
      "destination": "/marketing/07-website-conversion/landing-pages/coming-soon.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=30, stale-while-revalidate=120" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/og-coming-soon.gif",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=86400, stale-while-revalidate=604800" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
