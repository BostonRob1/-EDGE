{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=30, stale-while-revalidate=120" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
